{
  "extends": "../../packages/tsconfig/vite.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@spark/ui": ["../../packages/ui"],
      "@spark/ui/*": ["../../packages/ui/*"],
      "@spark/core": ["../../packages/core"],
      "@spark/core/*": ["../../packages/core/*"],
      "@spark/views": ["../../packages/views"],
      "@spark/views/*": ["../../packages/views/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
